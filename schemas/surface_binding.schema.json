{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velvet-ai.local/schemas/surface_binding.schema.json",
  "title": "SurfaceBinding",
  "description": "Association between a Velvet AI instance and a named surface.",
  "type": "object",
  "required": ["binding_id", "surface_id", "surface_type", "bound_instance_id", "trusted_by", "allowed_memory_classes", "denied_memory_classes", "created_at"],
  "additionalProperties": false,
  "properties": {
    "binding_id":             { "type": "string", "minLength": 1 },
    "surface_id":             { "type": "string", "minLength": 1 },
    "surface_type":           { "type": "string", "minLength": 1 },
    "bound_instance_id":      { "type": "string", "minLength": 1 },
    "trusted_by":             { "type": "string", "minLength": 1 },
    "allowed_memory_classes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "denied_memory_classes":  { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "receipt_anchor":         { "type": ["string", "null"] },
    "created_at":             { "type": "string", "minLength": 1 }
  }
}
